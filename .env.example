# LLM Configuration
GOLEM_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Custom OpenAI-compatible provider example:
# GOLEM_MODEL=codex:gpt-5.3-codex
# CODEX_API_KEY=your-key-here
# CODEX_BASE_URL=https://your-codex-endpoint.example.com/v1

# Agent Settings
GOLEM_MAX_TOOL_ITER=15
GOLEM_SHELL_TIMEOUT=30s
GOLEM_TAPE_DIR=~/.golem/tapes
GOLEM_CONTEXT_STRATEGY=masking
GOLEM_EXECUTOR=local
GOLEM_LOG_LEVEL=info

# Telegram (future)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOW_FROM=

# Lark (future)
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_VERIFY_TOKEN=
# LARK_WEBHOOK_PORT=9999

# mem9 Cloud Memory (optional — see configs/mem9/README.md)
# MEM9_API_URL=https://api.mem9.ai
# MEM9_SPACE_ID=your-space-id
